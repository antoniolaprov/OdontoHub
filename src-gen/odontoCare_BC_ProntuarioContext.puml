@startuml

skinparam componentStyle uml2

package "'Prontuario' Aggregate" <<Rectangle>> {
	class Prontuario <<(A,#fffab8) Aggregate Root>> {
		Long pacienteId
		Date dataAbertura
		String justificativaEncerramento
		Date dataEncerramento
		ProntuarioId prontuarioId
		StatusProntuario status
	}
	class FichaClinica <<(E,DarkSeaGreen) Entity>> {
		Long agendamentoId
		Date dataAtendimento
		String odontograma
		String queixas
		String achadosClinicos
		Boolean confirmada
		FichaClinicaId fichaClinicaId
		ProntuarioId prontuarioId
	}
	class ProntuarioId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	class FichaClinicaId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	class Evolucao <<(V,DarkSeaGreen) Value Object>> {
		String descricao
		Date dataRegistro
		String responsavel
	}
	enum StatusProntuario {
		ATIVO
		ENCERRADO
	}
	class ProntuarioAberto <<(E,#ff9f4b) Domain Event>> {
		Long pacienteId
		ProntuarioId prontuarioId
	}
	class FichaClinicaConfirmada <<(E,#ff9f4b) Domain Event>> {
		FichaClinicaId fichaClinicaId
		ProntuarioId prontuarioId
	}
	class ProntuarioEncerrado <<(E,#ff9f4b) Domain Event>> {
		String justificativa
		ProntuarioId prontuarioId
	}
}
package "'Anamnese' Aggregate" <<Rectangle>> {
	class Anamnese <<(A,#fffab8) Aggregate Root>> {
		Long pacienteId
		Date dataRegistro
		String responsavel
		String alergias
		String contraindicacoes
		String condicoesSistemicas
		AnamneseId anamneseId
	}
	class AnamneseId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	class VersaoAnamnese <<(V,DarkSeaGreen) Value Object>> {
		Integer numero
		Date dataAlteracao
		String responsavel
		String snapshot
	}
	class AnamneseRegistrada <<(E,#ff9f4b) Domain Event>> {
		Long pacienteId
		AnamneseId anamneseId
	}
	class AnamneseAtualizada <<(E,#ff9f4b) Domain Event>> {
		Integer novaVersao
		String responsavel
		AnamneseId anamneseId
	}
	class AlergiaDetectada <<(E,#ff9f4b) Domain Event>> {
		Long pacienteId
		String substancia
	}
}
package "'TCLE' Aggregate" <<Rectangle>> {
	class TermoConsentimento <<(A,#fffab8) Aggregate Root>> {
		Long pacienteId
		Long planoTratamentoId
		Date dataAssinatura
		String versao
		String justificativaSubstituicao
		TCLEId tcleId
		StatusTCLE status
	}
	class TCLEId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	enum StatusTCLE {
		PENDENTE
		ASSINADO
		SUBSTITUIDO
	}
	class TCLEAssinado <<(E,#ff9f4b) Domain Event>> {
		Long planoTratamentoId
		Long pacienteId
		TCLEId tcleId
	}
	class TCLESubstituido <<(E,#ff9f4b) Domain Event>> {
		String justificativa
		TCLEId tcleAntigoId
		TCLEId tcleNovoId
	}
}
Prontuario --> ProntuarioId : prontuarioId
Prontuario --> StatusProntuario : status
Anamnese --> AnamneseId : anamneseId
TermoConsentimento --> TCLEId : tcleId
FichaClinicaConfirmada --> ProntuarioId : prontuarioId
AnamneseAtualizada --> AnamneseId : anamneseId
TCLEAssinado --> TCLEId : tcleId
ProntuarioAberto --> ProntuarioId : prontuarioId
TCLESubstituido --> TCLEId : tcleNovoId
FichaClinicaConfirmada --> FichaClinicaId : fichaClinicaId
TermoConsentimento --> StatusTCLE : status
FichaClinica --> FichaClinicaId : fichaClinicaId
AnamneseRegistrada --> AnamneseId : anamneseId
TCLESubstituido --> TCLEId : tcleAntigoId
FichaClinica --> ProntuarioId : prontuarioId
ProntuarioEncerrado --> ProntuarioId : prontuarioId
legend left
  This bounded context implements the subdomain 'ProntuarioDomain'.
end legend


@enduml
