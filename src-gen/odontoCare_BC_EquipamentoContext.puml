@startuml

skinparam componentStyle uml2

package "'Equipamento' Aggregate" <<Rectangle>> {
	class Equipamento <<(A,#fffab8) Aggregate Root>> {
		String nome
		String modelo
		String fabricante
		Integer periodicidadeManutencaoDias
		Date ultimaManutencao
		Date proximaManutencao
		Boolean ativo
		EquipamentoId equipamentoId
		StatusEquipamento status
	}
	class EquipamentoId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	enum StatusEquipamento {
		DISPONIVEL
		EM_MANUTENCAO
		INDISPONIVEL
	}
	class AlertaManutencaoEmitido <<(E,#ff9f4b) Domain Event>> {
		String nomeEquipamento
		Date proximaManutencao
		Integer diasRestantes
		EquipamentoId equipamentoId
	}
	class EquipamentoIndisponivel <<(E,#ff9f4b) Domain Event>> {
		String motivo
		EquipamentoId equipamentoId
	}
	class EquipamentoDisponivel <<(E,#ff9f4b) Domain Event>> {
		EquipamentoId equipamentoId
	}
}
package "'Manutencao' Aggregate" <<Rectangle>> {
	class RegistroManutencao <<(A,#fffab8) Aggregate Root>> {
		Long equipamentoId
		Date dataInicio
		Date dataFim
		String responsavelTecnico
		String descricaoIntervencao
		BigDecimal custo
		ManutencaoId manutencaoId
		TipoManutencao tipo
	}
	class ManutencaoId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	enum TipoManutencao {
		PREVENTIVA
		CORRETIVA
	}
	class ManutencaoIniciada <<(E,#ff9f4b) Domain Event>> {
		Long equipamentoId
		ManutencaoId manutencaoId
		TipoManutencao tipo
	}
	class ManutencaoConcluida <<(E,#ff9f4b) Domain Event>> {
		Long equipamentoId
		Date dataFim
		BigDecimal custo
		ManutencaoId manutencaoId
	}
}
RegistroManutencao --> ManutencaoId : manutencaoId
RegistroManutencao --> TipoManutencao : tipo
ManutencaoConcluida --> ManutencaoId : manutencaoId
Equipamento --> StatusEquipamento : status
EquipamentoDisponivel --> EquipamentoId : equipamentoId
EquipamentoIndisponivel --> EquipamentoId : equipamentoId
ManutencaoIniciada --> ManutencaoId : manutencaoId
Equipamento --> EquipamentoId : equipamentoId
AlertaManutencaoEmitido --> EquipamentoId : equipamentoId
ManutencaoIniciada --> TipoManutencao : tipo
legend left
  This bounded context implements the subdomain 'EquipamentoDomain'.
end legend


@enduml
