@startuml

skinparam componentStyle uml2

package "'MaterialConsumivel' Aggregate" <<Rectangle>> {
	class MaterialConsumivel <<(A,#fffab8) Aggregate Root>> {
		String nome
		String unidadeMedida
		int quantidadeEmEstoque
		int pontoMinimo
		Date ultimaAtualizacao
		MaterialId id
	}
	class Reposicao <<(E,DarkSeaGreen) Entity>> {
		String fornecedor
		int quantidade
		double custoUnitario
		Date dataEntrada
		ReposicaoId id
		ReposicaomaterialId materialId
	}
	class ReposicaomaterialId <<(V,DarkSeaGreen) Value Object>> {
		Long materialId
	}
	class MaterialId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	class ReposicaoId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	class ReposicaoRegistrada <<(E,#ff9f4b) Domain Event>> {
		Long materialId
		int quantidade
		double custoUnitario
		double valorTotalLancamento
		ReposicaoId reposicaoId
	}
	class EstoqueBaixoAlertado <<(E,#ff9f4b) Domain Event>> {
		Long materialId
		String nomeMaterial
		int saldoAtual
		int pontoMinimo
	}
	class ConsumoRegistrado <<(E,#ff9f4b) Domain Event>> {
		Long materialId
		int quantidadeConsumida
		Long procedimentoOrigemId
	}
	class MaterialService <<(S,DarkSeaGreen) Service>> {
		void registrarReposicao(MaterialId materialId, String fornecedor, int quantidade, double custoUnitario)
		void descontarConsumo(MaterialId materialId, int quantidade, Long procedimentoId)
		boolean estoqueBaixo(MaterialId materialId)
	}
}
package "'Instrumento' Aggregate" <<Rectangle>> {
	class Instrumento <<(A,#fffab8) Aggregate Root>> {
		String nome
		String categoria
		Date dataUltimaEsterilizacao
		Date dataVencimento
		int prazoValidadeDias
		String responsavelEsterilizacao
		InstrumentoId id
		StatusEsterilizacao status
	}
	class InstrumentoId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	enum StatusEsterilizacao {
		ESTERIL
		CONTAMINADO
		VENCIDO
	}
	class InstrumentoEsterilizado <<(E,#ff9f4b) Domain Event>> {
		Date dataEsterilizacao
		String responsavel
		Date novaDataVencimento
		InstrumentoId instrumentoId
	}
	class InstrumentoContaminado <<(E,#ff9f4b) Domain Event>> {
		InstrumentoId instrumentoId
	}
	class InstrumentoVencido <<(E,#ff9f4b) Domain Event>> {
		String nome
		InstrumentoId instrumentoId
	}
	class InstrumentoService <<(S,DarkSeaGreen) Service>> {
		void marcarComoEsteril(InstrumentoId instrumentoId, Date dataEsterilizacao, String responsavel)
		void marcarComoContaminado(InstrumentoId instrumentoId)
		void recalcularValidadeGlobal(int novoPrazoDias)
		void verificarEAtualizarVencidos()
		void listarEstereisDentroDoPrazo()
	}
}
Instrumento --> StatusEsterilizacao : status
InstrumentoContaminado --> InstrumentoId : instrumentoId
Reposicao --> ReposicaomaterialId : materialId
ReposicaoRegistrada --> ReposicaoId : reposicaoId
InstrumentoVencido --> InstrumentoId : instrumentoId
InstrumentoEsterilizado --> InstrumentoId : instrumentoId
Reposicao --> ReposicaoId : id
Instrumento --> InstrumentoId : id
MaterialConsumivel --> MaterialId : id
legend left
  This bounded context implements the subdomain 'EstoqueSubdomain'.
end legend


@enduml
