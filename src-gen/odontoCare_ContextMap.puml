@startuml

skinparam componentStyle uml2

component [PacienteContext]
note right of [PacienteContext]
Gerencia o cadastro central de 
pacientes do consultorio odontologico. 

end note
component [AgendamentoContext]
note right of [AgendamentoContext]
Gerencia a reserva de horarios, 
classificando consultas e retornos, 
evitando conflitos e bloqueando 
inadimplentes. 
end note
component [ProntuarioContext]
note right of [ProntuarioContext]
Registra e mantem o historico 
clinico legal e longitudinal de 
cada paciente. 
end note
component [TratamentoContext]
note right of [TratamentoContext]
Organiza e sequencia os procedimentos 
clinicos necessarios para restabelecer 
ou manter a saude bucal do paciente. 

end note
component [FinanceiroContext]
note right of [FinanceiroContext]
Consolida as operacoes financeiras 
do consultorio: orcamentos, pagamentos, 
inadimplencia e fluxo de caixa. 

end note
component [EspecialistaContext]
note right of [EspecialistaContext]
Gerencia os especialistas convidados, 
suas regras de comissao e os repasses 
financeiros. 
end note
component [EstoqueContext]
note right of [EstoqueContext]
Controla o estoque de materiais 
consumiveis, automatizando baixas 
e alertas de reposicao. 
end note
component [InstrumentalContext]
note right of [InstrumentalContext]
Controla o ciclo de uso e esterilizacao 
dos instrumentos reutilizaveis 
do consultorio. 
end note
component [EquipamentoContext]
note right of [EquipamentoContext]
Controla a disponibilidade e as 
manutencoes preventivas e corretivas 
dos equipamentos do consultorio. 

end note

interface "RESTful HTTP" as AgendamentoContext_to_PacienteContext
[PacienteContext] --> AgendamentoContext_to_PacienteContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
AgendamentoContext_to_PacienteContext <.. [AgendamentoContext] : use Aggregate Paciente via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as ProntuarioContext_to_PacienteContext
[PacienteContext] --> ProntuarioContext_to_PacienteContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
ProntuarioContext_to_PacienteContext <.. [ProntuarioContext] : use Aggregate Paciente via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as FinanceiroContext_to_PacienteContext
[PacienteContext] --> FinanceiroContext_to_PacienteContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
FinanceiroContext_to_PacienteContext <.. [FinanceiroContext] : use Aggregate Paciente via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as TratamentoContext_to_PacienteContext
[PacienteContext] --> TratamentoContext_to_PacienteContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
TratamentoContext_to_PacienteContext <.. [TratamentoContext] : use Aggregate Paciente via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as AgendamentoContext_to_TratamentoContext
[TratamentoContext] --> AgendamentoContext_to_TratamentoContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
AgendamentoContext_to_TratamentoContext <.. [AgendamentoContext] : use Aggregate PlanoTratamento via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as AgendamentoContext_to_FinanceiroContext
[FinanceiroContext] --> AgendamentoContext_to_FinanceiroContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
AgendamentoContext_to_FinanceiroContext <.. [AgendamentoContext] : use Aggregate Inadimplencia via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as TratamentoContext_to_ProntuarioContext
[ProntuarioContext] --> TratamentoContext_to_ProntuarioContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
TratamentoContext_to_ProntuarioContext <.. [TratamentoContext] : use Aggregates Prontuario, Anamnese, TCLE via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as FinanceiroContext_to_TratamentoContext
[TratamentoContext] --> FinanceiroContext_to_TratamentoContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
FinanceiroContext_to_TratamentoContext <.. [FinanceiroContext] : use Aggregate PlanoTratamento via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as TratamentoContext_to_EspecialistaContext
[EspecialistaContext] --> TratamentoContext_to_EspecialistaContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
TratamentoContext_to_EspecialistaContext <.. [TratamentoContext] : use Aggregate Especialista via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as EspecialistaContext_to_FinanceiroContext
[FinanceiroContext] --> EspecialistaContext_to_FinanceiroContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
EspecialistaContext_to_FinanceiroContext <.. [EspecialistaContext] : use Aggregate Pagamento via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as TratamentoContext_to_EstoqueContext
[EstoqueContext] --> TratamentoContext_to_EstoqueContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
TratamentoContext_to_EstoqueContext <.. [TratamentoContext] : use Aggregate MaterialConsumivel via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as FinanceiroContext_to_EstoqueContext
[EstoqueContext] --> FinanceiroContext_to_EstoqueContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
FinanceiroContext_to_EstoqueContext <.. [FinanceiroContext] : use Aggregate Reposicao via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as TratamentoContext_to_InstrumentalContext
[InstrumentalContext] --> TratamentoContext_to_InstrumentalContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
TratamentoContext_to_InstrumentalContext <.. [TratamentoContext] : use Aggregate Instrumento via ANTICORRUPTION_LAYER

interface "RESTful HTTP" as TratamentoContext_to_EquipamentoContext
[EquipamentoContext] --> TratamentoContext_to_EquipamentoContext : OPEN_HOST_SERVICE, PUBLISHED_LANGUAGE
TratamentoContext_to_EquipamentoContext <.. [TratamentoContext] : use Aggregate Equipamento via ANTICORRUPTION_LAYER

