@startuml

skinparam componentStyle uml2

package "'Orcamento' Aggregate" <<Rectangle>> {
	class Orcamento <<(A,#fffab8) Aggregate Root>> {
		Long planoTratamentoId
		Long pacienteId
		BigDecimal valorTotal
		Boolean complementar
		Date dataGeracao
		Date dataAprovacao
		String formaAprovacao
		OrcamentoId orcamentoId
		StatusOrcamento status
	}
	class OrcamentoId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	class ItemOrcamento <<(V,DarkSeaGreen) Value Object>> {
		Long procedimentoId
		String descricao
		BigDecimal valorUnitario
	}
	enum StatusOrcamento {
		PENDENTE
		APROVADO
		RECUSADO
	}
	class OrcamentoGerado <<(E,#ff9f4b) Domain Event>> {
		Long planoTratamentoId
		BigDecimal valorTotal
		OrcamentoId orcamentoId
	}
	class OrcamentoAprovado <<(E,#ff9f4b) Domain Event>> {
		Date dataAprovacao
		String formaAprovacao
		OrcamentoId orcamentoId
	}
}
package "'Pagamento' Aggregate" <<Rectangle>> {
	class Pagamento <<(A,#fffab8) Aggregate Root>> {
		Long orcamentoId
		Long pacienteId
		BigDecimal valorTotal
		Date dataRegistro
		PagamentoId pagamentoId
		TipoPagamento tipo
	}
	class Parcela <<(E,DarkSeaGreen) Entity>> {
		Integer numero
		BigDecimal valor
		Date dataVencimento
		Date dataPagamento
		ParcelaId parcelaId
		StatusParcela status
	}
	class PagamentoId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	class ParcelaId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	enum TipoPagamento {
		A_VISTA
		PARCELADO
	}
	enum StatusParcela {
		PENDENTE
		LIQUIDADA
		INADIMPLENTE
	}
	class ParcelaLiquidada <<(E,#ff9f4b) Domain Event>> {
		Long pacienteId
		BigDecimal valor
		Date dataPagamento
		ParcelaId parcelaId
		PagamentoId pagamentoId
	}
	class ParcelaVencidaSemPagamento <<(E,#ff9f4b) Domain Event>> {
		Long pacienteId
		Date dataVencimento
		ParcelaId parcelaId
		PagamentoId pagamentoId
	}
}
package "'Inadimplencia' Aggregate" <<Rectangle>> {
	class RegistroInadimplencia <<(A,#fffab8) Aggregate Root>> {
		Long pacienteId
		Long parcelaId
		Date dataVencimento
		Boolean bloqueioAtivo
		String autorizacaoDesbloqueio
		String responsavelAutorizacao
		InadimplenciaId inadimplenciaId
	}
	class InadimplenciaId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	class RegistroCobranca <<(V,DarkSeaGreen) Value Object>> {
		Date data
		String responsavel
		String resultado
		String observacao
	}
	class BloqueioAgendamentoAtivado <<(E,#ff9f4b) Domain Event>> {
		Long pacienteId
		InadimplenciaId inadimplenciaId
	}
	class BloqueioAgendamentoRemovido <<(E,#ff9f4b) Domain Event>> {
		Long pacienteId
		String autorizacao
		InadimplenciaId inadimplenciaId
	}
	class InadimplenciaRegularizada <<(E,#ff9f4b) Domain Event>> {
		Long pacienteId
		Date dataQuitacao
		InadimplenciaId inadimplenciaId
	}
}
package "'LancamentoFinanceiro' Aggregate" <<Rectangle>> {
	class LancamentoFinanceiro <<(A,#fffab8) Aggregate Root>> {
		BigDecimal valor
		Date data
		String categoria
		String descricao
		String justificativa
		Boolean geradoAutomaticamente
		String origemReferencia
		LancamentoId lancamentoId
		TipoLancamento tipo
	}
	class LancamentoId <<(V,DarkSeaGreen) Value Object>> {
		Long id
	}
	enum TipoLancamento {
		ENTRADA
		SAIDA
	}
	class EntradaRegistrada <<(E,#ff9f4b) Domain Event>> {
		BigDecimal valor
		Date data
		String origem
		LancamentoId lancamentoId
	}
	class SaidaRegistrada <<(E,#ff9f4b) Domain Event>> {
		BigDecimal valor
		String categoria
		LancamentoId lancamentoId
	}
}
RegistroInadimplencia --> InadimplenciaId : inadimplenciaId
Orcamento --> StatusOrcamento : status
OrcamentoGerado --> OrcamentoId : orcamentoId
ParcelaVencidaSemPagamento --> PagamentoId : pagamentoId
ParcelaVencidaSemPagamento --> ParcelaId : parcelaId
Pagamento --> TipoPagamento : tipo
Parcela --> ParcelaId : parcelaId
ParcelaLiquidada --> ParcelaId : parcelaId
BloqueioAgendamentoAtivado --> InadimplenciaId : inadimplenciaId
SaidaRegistrada --> LancamentoId : lancamentoId
BloqueioAgendamentoRemovido --> InadimplenciaId : inadimplenciaId
Parcela --> StatusParcela : status
LancamentoFinanceiro --> TipoLancamento : tipo
OrcamentoAprovado --> OrcamentoId : orcamentoId
Pagamento --> PagamentoId : pagamentoId
ParcelaLiquidada --> PagamentoId : pagamentoId
InadimplenciaRegularizada --> InadimplenciaId : inadimplenciaId
EntradaRegistrada --> LancamentoId : lancamentoId
LancamentoFinanceiro --> LancamentoId : lancamentoId
Orcamento --> OrcamentoId : orcamentoId
legend left
  This bounded context implements the subdomain 'FinanceiroDomain'.
end legend


@enduml
